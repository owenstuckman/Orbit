# ============================================================
# Orbit — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed.
# ============================================================

# ------------------------------------------------------------
# Supabase (required)
# Get these from: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# Supabase Edge Function Secrets
# Set these with: supabase secrets set KEY=value
# These are NOT read by the frontend — they live server-side.
# Listed here for reference and local edge function testing.
# ------------------------------------------------------------

# Email — Resend API (https://resend.com)
# Used by: supabase/functions/send-email/index.ts
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Orbit <noreply@yourdomain.com>

# ML Model API — QC confidence scoring
# Used by: supabase/functions/qc-ai-review/index.ts
# Without ML_API_URL set, the edge function falls back to p0=0.8 for all reviews.
#
# Hosted on Render. ML_API_KEY is optional — only set it if you configured an
# API_KEY environment variable in your Render service. If you did, put that
# same value here. Do NOT use your Render account API key (starts with rnd_) —
# that is a different key for Render's management API, not your ML service.
ML_API_URL=https://your-ml-api.onrender.com
# ML_API_KEY=your-ml-service-api-key  # optional — must match API_KEY set in Render service env vars

# ------------------------------------------------------------
# Feature Flags (optional overrides, for local dev only)
# ------------------------------------------------------------
VITE_ENABLE_AI_QC=true
VITE_ENABLE_CONTRACTS=true
