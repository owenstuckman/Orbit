# ============================================================
# Orbit — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed.
# ============================================================

# ------------------------------------------------------------
# Supabase (required)
# Get these from: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# Supabase Edge Function Secrets
# Set these with: supabase secrets set KEY=value
# These are NOT read by the frontend — they live server-side.
# Listed here for reference and local edge function testing.
# ------------------------------------------------------------

# Email — Resend API (https://resend.com)
# Used by: supabase/functions/send-email/index.ts
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Orbit <noreply@yourdomain.com>

# ML Model API — QC confidence scoring
# Used by: supabase/functions/qc-ai-review/index.ts
# Without these set, the edge function falls back to p0=0.8 for all reviews.
ML_API_URL=https://your-ml-api.example.com
ML_API_KEY=your-ml-api-key-here

# ------------------------------------------------------------
# Feature Flags (optional overrides, for local dev only)
# ------------------------------------------------------------
VITE_ENABLE_AI_QC=true
VITE_ENABLE_CONTRACTS=true
